  "entries": [
    {
      "headword": "mapu",
      "senses": [
        {
          "part_of_speech": "n",
          "definitions": [
            {
              "content": "tierra, terreno, país, región, etc."
            },
            {
              "content": "la gente del país, los de la misma tierra (en su totalidad)",
              "quotes": [
                {
                  "content": "iñ mapu"
                },
                {
                  "content": "iñ mapuñmaniel che",
                  "translation": "la gente de nuestra tierra o reducción"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "headword": "mapun",
      "senses": [
        {
          "part_of_speech": "intr",
          "definitions": [
            {
              "content": "tener derecho sobre un terreno",
              "quotes": [
                {
                  "content": "eymi mapulaymi faw",
                  "translation": "a ti no te toca terreno aquí"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "headword": "pichiñma",
      "senses": [
        {
